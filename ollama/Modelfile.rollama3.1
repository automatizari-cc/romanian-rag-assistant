FROM hf.co/mradermacher/RoLlama3.1-8b-Instruct-GGUF:Q4_K_M

# OpenLLM-Ro's upstream tokenizer_config.json ships the Llama Guard 3 chat
# template, not the Llama 3.1 Instruct template. Inherited by mradermacher's
# GGUF metadata; without this override every prompt gets classified as
# "safe"/"unsafe" instead of answered. See CLAUDE.md "Things to watch".
TEMPLATE """{{- if .System }}<|start_header_id|>system<|end_header_id|>

{{ .System }}<|eot_id|>
{{- end }}
{{- range .Messages }}
{{- if eq .Role "user" }}<|start_header_id|>user<|end_header_id|>

{{ .Content }}<|eot_id|>
{{- else if eq .Role "assistant" }}<|start_header_id|>assistant<|end_header_id|>

{{ .Content }}<|eot_id|>
{{- end }}
{{- end }}<|start_header_id|>assistant<|end_header_id|>


"""

PARAMETER stop "<|eot_id|>"
PARAMETER stop "<|start_header_id|>"
PARAMETER stop "<|end_header_id|>"

# The mradermacher GGUF metadata bakes in `PARAMETER temperature 0` from
# OpenLLM-Ro's upstream config (deterministic, set up for the Llama Guard
# classifier). Inherited via FROM unless overridden — making chat output
# bit-identical across runs and weirdly rigid. 0.5 is a balanced default
# for factual RAG: enough variation to break determinism without losing
# groundedness.
PARAMETER temperature 0.5
