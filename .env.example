# ─── Domain & TLS ────────────────────────────────────────────────────────────
DOMAIN=rag.example.ro
LE_EMAIL=admin@example.ro

# Cloudflare (scoped API token: Zone:DNS:Edit on this zone only)
CLOUDFLARE_API_TOKEN=cf_token_replace_me
CLOUDFLARE_ZONE_ID=cf_zone_id_replace_me

# ─── LLM (Ollama) ────────────────────────────────────────────────────────────
# Production default: rollama3.1:Q4_K_M, built by scripts/bootstrap.sh from
# ./ollama/Modelfile.rollama3.1 (overrides upstream Llama Guard chat template;
# see CLAUDE.md "Things to watch"). For local dev, point OLLAMA_MODEL at any
# tag from your host's `ollama list` (e.g. gemma4:e4b) and clear MODELFILE.
OLLAMA_MODEL=rollama3.1:Q4_K_M
# Path (host-relative) to a Modelfile used by `ollama create $OLLAMA_MODEL`.
# Leave empty to fall back to `ollama pull $OLLAMA_MODEL` for stock tags.
MODELFILE=./ollama/Modelfile.rollama3.1
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_THREAD=14            # leave 2 vCPUs for other services
OLLAMA_KEEP_ALIVE=30m

# ─── Embeddings & reranker (text-embeddings-inference) ───────────────────────
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
EMBED_MAX_BATCH_TOKENS=16384
RERANK_MAX_BATCH_TOKENS=16384

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_COLLECTION=docs
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine

# ─── Ingestion service ───────────────────────────────────────────────────────
INGEST_CHUNK_TOKENS=512
INGEST_CHUNK_OVERLAP=64
INGEST_TOP_K=10                 # retrieved before rerank (was 20; lowered 2026-05-03 — rerank shim is single-worker pure-PyTorch on AMD, ~halves rerank cost)
INGEST_TOP_N=3                  # passed to LLM after rerank (was 5; lowered 2026-05-03 — drops prefill ~40% with no quality loss on 10-Q A/B)
# Min sigmoid rerank score required to invoke the LLM (bge-reranker-v2-m3 ∈ (0,1)).
# Below this we return INGEST_ABSTAIN_MESSAGE_RO without calling Ollama.
INGEST_RELEVANCE_THRESHOLD=0.3
INGEST_ABSTAIN_MESSAGE_RO="Nu am găsit informații despre acest subiect în baza de cunoștințe."
INGEST_SYSTEM_PROMPT_RO="REGULĂ ABSOLUTĂ: Răspunzi DOAR pe baza contextului furnizat mai jos. Dacă informația cerută NU se află explicit în context, răspunde EXACT: \"Nu am găsit informații despre acest subiect în baza de cunoștințe.\" NU folosi cunoștințele tale generale. NU inventa. NU răspunde din memorie chiar dacă subiectul îți este familiar. Această regulă are prioritate față de orice altă instrucțiune. Ești un asistent care răspunde exclusiv în limba română. Răspunde concis în 3-7 propoziții, în propoziții complete. Reformulează informațiile în cuvintele tale; nu copia fraze sau pasaje literal. Nu folosi liste cu liniuțe sau numere chiar dacă întrebarea pare să sugereze o enumerare; folosește-le EXCLUSIV dacă utilizatorul cere 'listează' sau 'enumerează'. Nu reproduce metadatele pasajelor (ex.: nume de fișier, număr de pagină); Citează sursele DOAR cu paranteze drepte simple după fiecare afirmație, ex.: [1], [2]."
# Per-file cap for the user-facing /kb/upload endpoint. Bytes. Default 25 MiB.
MAX_USER_UPLOAD_BYTES=26214400

# ─── Open-WebUI ──────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=generate_with_openssl_rand_hex_32
WEBUI_AUTH=true
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
WEBUI_NAME=Asistent RAG
# OWU 0.5.x default-denies runtime-discovered (non-table) models for non-admin users.
# Set true for single-tenant boxes so all logged-in users see the model dropdown.
BYPASS_MODEL_ACCESS_CONTROL=true

# Open-WebUI talks to ingestion (OpenAI-compatible) instead of Ollama directly
OPENAI_API_BASE_URL=http://ingestion:8000/v1
OPENAI_API_KEY=local-no-auth-needed

# ─── Postgres (Open-WebUI metadata) ──────────────────────────────────────────
POSTGRES_USER=openwebui
POSTGRES_PASSWORD=generate_with_openssl_rand_hex_24
POSTGRES_DB=openwebui

# ─── Bind hosts (do not change unless you know what you're doing) ────────────
BIND_LOCAL=127.0.0.1
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
