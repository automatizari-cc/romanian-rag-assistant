# ─── Domain & TLS ────────────────────────────────────────────────────────────
DOMAIN=rag.example.ro
LE_EMAIL=admin@example.ro

# Cloudflare (scoped API token: Zone:DNS:Edit on this zone only)
CLOUDFLARE_API_TOKEN=cf_token_replace_me
CLOUDFLARE_ZONE_ID=cf_zone_id_replace_me

# ─── LLM (Ollama) ────────────────────────────────────────────────────────────
# Production default: rollama3.1:8b-instruct-q4_k_m (created by scripts/bootstrap.sh).
# For local dev, set this to a tag from your host's `ollama list`, e.g. gemma4:e4b
OLLAMA_MODEL=rollama3.1:8b-instruct-q4_k_m
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_THREAD=14            # leave 2 vCPUs for other services
OLLAMA_KEEP_ALIVE=30m

# ─── Embeddings & reranker (text-embeddings-inference) ───────────────────────
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
EMBED_MAX_BATCH_TOKENS=16384
RERANK_MAX_BATCH_TOKENS=16384

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_COLLECTION=docs
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine

# ─── Ingestion service ───────────────────────────────────────────────────────
INGEST_CHUNK_TOKENS=512
INGEST_CHUNK_OVERLAP=64
INGEST_TOP_K=10                 # retrieved before rerank (was 20; lowered 2026-05-03 — rerank shim is single-worker pure-PyTorch on AMD, ~halves rerank cost)
INGEST_TOP_N=3                  # passed to LLM after rerank (was 5; lowered 2026-05-03 — drops prefill ~40% with no quality loss on 10-Q A/B)
INGEST_SYSTEM_PROMPT_RO="Ești un asistent care răspunde exclusiv în limba română, bazându-te strict pe contextul furnizat. Dacă răspunsul nu se află în context, spune clar că nu știi. Răspunde concis în 3-7 propoziții, în propoziții complete. Reformulează informațiile în cuvintele tale; nu copia fraze sau pasaje literal. Nu folosi liste cu liniuțe sau numere chiar dacă întrebarea pare să sugereze o enumerare; folosește-le EXCLUSIV dacă utilizatorul cere 'listează' sau 'enumerează'. Nu reproduce metadatele pasajelor (ex.: nume de fișier, număr de pagină); dacă citezi sursele, folosește doar paranteze drepte simple, ex.: [1], [2]."
# Per-file cap for the user-facing /kb/upload endpoint. Bytes. Default 25 MiB.
MAX_USER_UPLOAD_BYTES=26214400

# ─── Open-WebUI ──────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=generate_with_openssl_rand_hex_32
WEBUI_AUTH=true
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
WEBUI_NAME=Asistent RAG

# Open-WebUI talks to ingestion (OpenAI-compatible) instead of Ollama directly
OPENAI_API_BASE_URL=http://ingestion:8000/v1
OPENAI_API_KEY=local-no-auth-needed

# ─── Postgres (Open-WebUI metadata) ──────────────────────────────────────────
POSTGRES_USER=openwebui
POSTGRES_PASSWORD=generate_with_openssl_rand_hex_24
POSTGRES_DB=openwebui

# ─── Bind hosts (do not change unless you know what you're doing) ────────────
BIND_LOCAL=127.0.0.1
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
